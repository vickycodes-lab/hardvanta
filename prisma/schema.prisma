// Prisma schema for hardvanta storefront.
// DB: PostgreSQL (Supabase). Run `npx prisma db push` then `npm run seed`.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum Role {
  USER
  ADMIN
}

enum OrderStatus {
  PENDING
  PROCESSING
  SHIPPED
  DELIVERED
  CANCELLED
}

model User {
  id            String     @id @default(cuid())
  name          String?
  email         String     @unique
  emailVerified DateTime?
  password      String?
  role          Role       @default(USER)
  image         String?
  createdAt     DateTime   @default(now())
  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  reviews       Review[]
  cart          CartItem[]
}

// NextAuth adapter models (OAuth/Google support)
model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// Short-lived 6-digit codes for two-factor login (step after password).
model LoginOtp {
  id        String   @id @default(cuid())
  email     String
  code      String
  expires   DateTime
  createdAt DateTime @default(now())

  @@index([email])
}

model Category {
  slug String @id
  name String
  icon String
}

model Product {
  id          String      @id @default(cuid())
  slug        String      @unique
  name        String
  description String
  price       Int
  salePrice   Int?
  stock       Int         @default(0)
  category    String
  brand       String
  image       String
  rating      Float       @default(0)
  reviewCount Int         @default(0)
  featured    Boolean     @default(false)
  createdAt   DateTime    @default(now())
  orderItems  OrderItem[]
  reviews     Review[]
  cartItems   CartItem[]

  @@index([category])
}

model Order {
  id            String      @id @default(cuid())
  userId        String
  user          User        @relation(fields: [userId], references: [id])
  items         OrderItem[]
  total         Int
  status        OrderStatus @default(PENDING)
  address       Json
  paymentMethod String      @default("COD")
  paymentId     String?
  razorpayOrderId String?
  createdAt     DateTime    @default(now())
}

model OrderItem {
  id        String  @id @default(cuid())
  orderId   String
  order     Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id])
  name      String
  quantity  Int
  price     Int
}

model CartItem {
  id        String  @id @default(cuid())
  userId    String
  user      User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  quantity  Int

  @@unique([userId, productId])
}

model Review {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId String
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)
  rating    Int
  comment   String
  createdAt DateTime @default(now())
}
