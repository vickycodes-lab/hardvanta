# Example environment variables for hardvanta
# Copy this to .env and fill with your secrets

# Prisma (Postgres/Supabase)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hardvanta?schema=public"

# NextAuth
NEXTAUTH_SECRET="replace_with_random_string"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Supabase
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# Email (Resend)
RESEND_API_KEY=""
EMAIL_FROM="hardvanta <onboarding@example.com>"

# Razorpay
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# Google Places
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""
# Copy this file to .env.local and fill in real values. Never commit .env.local.

# --- Supabase Postgres ---
# Project Settings → Database → Connection string.
# Use the "Connection pooling" (pgBouncer, port 6543) string for DATABASE_URL
# and the "Direct connection" (port 5432) string for DIRECT_URL.
DATABASE_URL="postgresql://postgres.[ref]:[password]@[host]:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@[host]:5432/postgres"

# --- NextAuth ---
NEXTAUTH_URL="http://localhost:3000"
# Generate with: openssl rand -base64 32   (or any 32+ char random string)
NEXTAUTH_SECRET="replace-with-a-long-random-secret"

# --- Google OAuth ---
# console.cloud.google.com → APIs & Services → Credentials → OAuth client (Web).
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# --- Google Reviews (Places API) ---
# Enable "Places API (New)" in Google Cloud, create a restricted API key.
# Find your business Place ID: https://developers.google.com/maps/documentation/places/web-service/place-id
# Until both are set, the homepage shows sample reviews automatically.
GOOGLE_PLACES_API_KEY=""
GOOGLE_PLACE_ID=""

# --- Razorpay (online payments) ---
# dashboard.razorpay.com → Settings → API Keys → Generate Test Keys.
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""

# --- Supabase Storage (product image uploads) ---
# Supabase dashboard → Settings → API. Create a public bucket named "products".
NEXT_PUBLIC_SUPABASE_URL=""
SUPABASE_SERVICE_ROLE_KEY=""

# --- Resend (login OTP + order confirmation emails) ---
# resend.com → API Keys. EMAIL_FROM must be a verified sender/domain.
# Until RESEND_API_KEY is set, emails are logged to the server console
# (the OTP code prints in the terminal) so login still works in development.
RESEND_API_KEY=""
EMAIL_FROM="hardvanta <onboarding@resend.dev>"
